---
interface NavContent {
  services: string;
  pricing: string;
  process: string;
  contact: string;
  cta: string;
}

export interface Props {
  lang: 'en' | 'bg';
  nav: NavContent;
}

const { lang, nav } = Astro.props;
const homeUrl = lang === 'en' ? '/' : '/bg/';
const alternateUrl = lang === 'en' ? '/bg/' : '/';
const alternateLang = lang === 'en' ? 'BG' : 'EN';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">

      <!-- Logo -->
      <a href={homeUrl} class="flex items-center gap-2.5 group" aria-label="Pixflow Studio – Home">
        <picture>
          <source srcset="/logo.webp" type="image/webp" />
          <img
            src="/logo.png"
            alt="Pixflow Studio logo"
            class="h-10 w-auto group-hover:scale-105 transition-transform duration-200"
            style="filter: drop-shadow(0 0 1px rgba(255,255,255,0.9)) drop-shadow(0 0 10px rgba(245,158,11,0.45));"
          />
        </picture>
        <span class="font-bold text-white text-base tracking-tight hidden sm:inline">
          Pixflow<span class="text-brand-light"> Studio</span>
        </span>
      </a>

      <!-- Desktop navigation -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        <a href={`${homeUrl}#services`} class="px-3 py-2 text-slate-400 hover:text-white text-sm font-medium rounded-lg hover:bg-white/5 transition-all duration-150">
          {nav.services}
        </a>
        <a href={`${homeUrl}#pricing`} class="px-3 py-2 text-slate-400 hover:text-white text-sm font-medium rounded-lg hover:bg-white/5 transition-all duration-150">
          {nav.pricing}
        </a>
        <a href={`${homeUrl}#process`} class="px-3 py-2 text-slate-400 hover:text-white text-sm font-medium rounded-lg hover:bg-white/5 transition-all duration-150">
          {nav.process}
        </a>
        <a href={`${homeUrl}#contact`} class="px-3 py-2 text-slate-400 hover:text-white text-sm font-medium rounded-lg hover:bg-white/5 transition-all duration-150">
          {nav.contact}
        </a>
      </nav>

      <!-- Right side actions -->
      <div class="flex items-center gap-2 sm:gap-3">
        <!-- Language switcher -->
        <a
          href={alternateUrl}
          class="text-xs font-semibold text-slate-500 hover:text-white border border-white/10 hover:border-white/25 px-2.5 py-1.5 rounded-lg transition-all duration-150 tracking-widest uppercase"
          aria-label={`Switch to ${alternateLang}`}
        >
          {alternateLang}
        </a>

        <!-- CTA button (desktop) -->
        <a
          href={`${homeUrl}#contact`}
          class="hidden sm:inline-flex btn-primary text-sm px-4 py-2"
        >
          {nav.cta}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-slate-400 hover:text-white rounded-lg hover:bg-white/5 transition-all duration-150"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle navigation"
        >
          <svg id="menu-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="4" y1="7" x2="20" y2="7"/>
            <line x1="4" y1="12" x2="20" y2="12"/>
            <line x1="4" y1="17" x2="20" y2="17"/>
          </svg>
          <svg id="menu-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="md:hidden hidden border-t border-white/5 py-3 space-y-1"
      aria-label="Mobile navigation"
    >
      <a href={`${homeUrl}#services`} class="flex items-center px-3 py-2.5 text-slate-300 hover:text-white text-sm font-medium rounded-lg hover:bg-white/5 transition-all duration-150">
        {nav.services}
      </a>
      <a href={`${homeUrl}#pricing`} class="flex items-center px-3 py-2.5 text-slate-300 hover:text-white text-sm font-medium rounded-lg hover:bg-white/5 transition-all duration-150">
        {nav.pricing}
      </a>
      <a href={`${homeUrl}#process`} class="flex items-center px-3 py-2.5 text-slate-300 hover:text-white text-sm font-medium rounded-lg hover:bg-white/5 transition-all duration-150">
        {nav.process}
      </a>
      <a href={`${homeUrl}#contact`} class="flex items-center px-3 py-2.5 text-slate-300 hover:text-white text-sm font-medium rounded-lg hover:bg-white/5 transition-all duration-150">
        {nav.contact}
      </a>
      <div class="pt-2 pb-1">
        <a href={`${homeUrl}#contact`} class="btn-primary w-full text-sm py-2.5">
          {nav.cta}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  // Scroll: add background when scrolled
  const onScroll = () => {
    if (window.scrollY > 24) {
      header?.classList.add('bg-[#0A0B14]/95', 'border-b', 'border-white/[0.05]', 'shadow-lg', 'shadow-black/15');
    } else {
      header?.classList.remove('bg-[#0A0B14]/95', 'border-b', 'border-white/[0.05]', 'shadow-lg', 'shadow-black/15');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const scrolledClasses = ['bg-[#0A0B14]/95', 'border-b', 'border-white/[0.05]', 'shadow-lg', 'shadow-black/15'];

  function openMenu() {
    mobileMenu?.classList.remove('hidden');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    menuBtn?.setAttribute('aria-expanded', 'true');
    header?.classList.add(...scrolledClasses);
  }

  function closeMenu() {
    mobileMenu?.classList.add('hidden');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    menuBtn?.setAttribute('aria-expanded', 'false');
    if (window.scrollY <= 24) {
      header?.classList.remove(...scrolledClasses);
    }
  }

  // Mobile menu toggle
  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    isOpen ? closeMenu() : openMenu();
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => closeMenu());
  });
</script>
