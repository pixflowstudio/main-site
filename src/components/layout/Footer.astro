---
interface FooterContent {
  copyright: string;
  tagline: string;
  links: {
    services: string;
    pricing: string;
    process: string;
    contact: string;
  };
}

export interface Props {
  lang: 'en' | 'bg';
  footer: FooterContent;
  email: string;
  whatsapp: string;
}

const { lang, footer, email, whatsapp } = Astro.props;
const homeUrl = lang === 'en' ? '/' : '/bg/';
const alternateUrl = lang === 'en' ? '/bg/' : '/';
const alternateLang = lang === 'en' ? 'BG' : 'EN';
const currentYear = new Date().getFullYear();
---

<footer class="relative border-t border-white/[0.06] bg-[#080910]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-2">
        <a href={homeUrl} class="flex items-center gap-2.5 group mb-4 w-fit">
<span class="font-bold text-white text-sm tracking-tight">
            Pixflow<span class="text-brand-light"> Studio</span>
          </span>
        </a>
        <p class="text-slate-500 text-sm leading-relaxed max-w-xs">
          {footer.tagline}
        </p>
        <div class="mt-6 space-y-2">
          <a
            href={`mailto:${email}`}
            class="flex items-center gap-2 text-slate-400 hover:text-white text-sm transition-colors duration-150 group w-fit"
          >
            <svg class="text-brand-light flex-shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            {email}
          </a>
          <a
            href={whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-slate-400 hover:text-white text-sm transition-colors duration-150 w-fit"
          >
            <svg class="text-[#25D366] flex-shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>

      <!-- Navigation links -->
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-widest mb-5">
          {lang === 'en' ? 'Navigation' : 'Навигация'}
        </h3>
        <ul class="space-y-3" role="list">
          <li>
            <a href="#services" class="text-slate-400 hover:text-white text-sm transition-colors duration-150">
              {footer.links.services}
            </a>
          </li>
          <li>
            <a href="#pricing" class="text-slate-400 hover:text-white text-sm transition-colors duration-150">
              {footer.links.pricing}
            </a>
          </li>
          <li>
            <a href="#process" class="text-slate-400 hover:text-white text-sm transition-colors duration-150">
              {footer.links.process}
            </a>
          </li>
          <li>
            <a href="#contact" class="text-slate-400 hover:text-white text-sm transition-colors duration-150">
              {footer.links.contact}
            </a>
          </li>
        </ul>
      </div>

      <!-- Language & legal -->
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-widest mb-5">
          {lang === 'en' ? 'Language' : 'Език'}
        </h3>
        <ul class="space-y-3" role="list">
          <li>
            <a
              href="/"
              class={`text-sm transition-colors duration-150 ${lang === 'en' ? 'text-brand-light font-medium' : 'text-slate-400 hover:text-white'}`}
              aria-current={lang === 'en' ? 'page' : undefined}
            >
              English
            </a>
          </li>
          <li>
            <a
              href="/bg/"
              class={`text-sm transition-colors duration-150 ${lang === 'bg' ? 'text-brand-light font-medium' : 'text-slate-400 hover:text-white'}`}
              aria-current={lang === 'bg' ? 'page' : undefined}
            >
              Български
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal links -->
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-widest mb-5">
          {lang === 'en' ? 'Legal' : 'Правно'}
        </h3>
        <ul class="space-y-3" role="list">
          <li>
            <a
              href={lang === 'en' ? '/service-terms/' : '/bg/service-terms/'}
              class="text-slate-400 hover:text-white text-sm transition-colors duration-150"
            >
              {lang === 'en' ? "What's Included" : 'Какво е включено'}
            </a>
          </li>
          <li>
            <a
              href={lang === 'en' ? '/privacy/' : '/bg/privacy/'}
              class="text-slate-400 hover:text-white text-sm transition-colors duration-150"
            >
              {lang === 'en' ? 'Privacy Policy' : 'Поверителност'}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-slate-600 text-xs">
        {footer.copyright.replace('2025', String(currentYear))}
      </p>
      <p class="text-slate-700 text-xs">
        {lang === 'en' ? 'Designed & built with ♥ in Bulgaria' : 'Проектирано и изградено с ♥ в България'}
      </p>
    </div>
  </div>
</footer>
