---
interface TrustFeature {
  icon: string;
  title: string;
  description: string;
}

interface Testimonial {
  text: string;
  author: string;
  business: string;
}

interface TrustContent {
  badge: string;
  headline: string;
  subheadline: string;
  features: TrustFeature[];
  testimonials: Testimonial[];
}

export interface Props {
  trust: TrustContent;
}

const { trust } = Astro.props;

const icons: Record<string, string> = {
  contract: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="15" x2="15" y2="15"/><line x1="9" y1="11" x2="11" y2="11"/></svg>`,
  money: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>`,
  rocket: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`,
  transparent: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>`,
  mobile: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="20" x="5" y="2" rx="2"/><path d="M12 18h.01"/></svg>`,
  support: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
};
---

<section class="relative py-24 sm:py-32" aria-labelledby="trust-headline">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16 sm:mb-20">
      <p class="section-badge justify-center mb-4">{trust.badge}</p>
      <h2 id="trust-headline" class="section-headline mb-5">{trust.headline}</h2>
      <p class="section-subheadline mx-auto">{trust.subheadline}</p>
    </div>

    <!-- Features grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 mb-20">
      {trust.features.map((feature) => (
        <div class="card card-hover flex gap-4">
          <div class="w-10 h-10 rounded-lg bg-brand/10 border border-brand/20 flex items-center justify-center text-brand-light flex-shrink-0 mt-0.5">
            <Fragment set:html={icons[feature.icon] || icons.support} />
          </div>
          <div>
            <h3 class="text-white font-semibold text-sm mb-1.5">{feature.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Testimonials -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {trust.testimonials.map((testimonial) => (
        <figure class="card card-hover">
          <!-- Quote mark -->
          <div class="text-brand/30 text-5xl font-black leading-none mb-3 select-none" aria-hidden="true">"</div>
          <blockquote class="text-slate-300 text-sm leading-relaxed mb-5">
            {testimonial.text}
          </blockquote>
          <figcaption class="flex items-center gap-3 pt-4 border-t border-white/[0.06]">
            <!-- Avatar placeholder -->
            <div class="w-8 h-8 rounded-full bg-gradient-brand flex items-center justify-center text-white text-xs font-bold flex-shrink-0" aria-hidden="true">
              {testimonial.author.charAt(0)}
            </div>
            <div>
              <div class="text-white text-sm font-medium">{testimonial.author}</div>
              <div class="text-slate-600 text-xs">{testimonial.business}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>

  </div>
</section>
