---
interface PricingPlan {
  name: string;
  price: string;
  currency: string;
  period: string;
  description: string;
  featured: boolean;
  badge: string | null;
  cta: string;
  features: string[];
}

interface PricingContent {
  badge: string;
  headline: string;
  subheadline: string;
  plans: PricingPlan[];
  note: string;
}

export interface Props {
  pricing: PricingContent;
}

const { pricing } = Astro.props;
---

<section id="pricing" class="relative py-24 sm:py-32" aria-labelledby="pricing-headline">
  <!-- Subtle background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-brand/[0.03] to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16 sm:mb-20">
      <p class="section-badge justify-center mb-4">{pricing.badge}</p>
      <h2 id="pricing-headline" class="section-headline mb-5">{pricing.headline}</h2>
      <p class="section-subheadline mx-auto">{pricing.subheadline}</p>
    </div>

    <!-- Pricing cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6">
      {pricing.plans.map((plan) => (
        <div
          class:list={[
            'relative flex flex-col rounded-2xl p-7 transition-all duration-300',
            plan.featured
              ? 'bg-brand border-2 border-brand shadow-2xl shadow-brand/20 scale-[1.02] md:scale-105'
              : 'card card-hover'
          ]}
          aria-label={`${plan.name} plan`}
        >
          <!-- Popular badge -->
          {plan.badge && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="bg-white text-brand text-xs font-bold px-3 py-1 rounded-full tracking-wide shadow-lg">
                {plan.badge}
              </span>
            </div>
          )}

          <!-- Plan name & description -->
          <div class="mb-6">
            <h3 class:list={['text-base font-bold mb-2', plan.featured ? 'text-white/90' : 'text-white']}>
              {plan.name}
            </h3>
            <p class:list={['text-sm leading-relaxed', plan.featured ? 'text-white/70' : 'text-slate-500']}>
              {plan.description}
            </p>
          </div>

          <!-- Price -->
          <div class="mb-7">
            <div class="flex items-end gap-1">
              <span class:list={['text-4xl font-black tracking-tight', plan.featured ? 'text-white' : 'text-white']}>
                {plan.currency}{plan.price}
              </span>
              <span class:list={['text-sm mb-1.5', plan.featured ? 'text-white/60' : 'text-slate-500']}>
                /{plan.period}
              </span>
            </div>
          </div>

          <!-- Features list -->
          <ul class="space-y-3 mb-8 flex-1" role="list">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2.5">
                <svg
                  class:list={['flex-shrink-0 mt-0.5', plan.featured ? 'text-white' : 'text-brand-light']}
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span class:list={['text-sm leading-snug', plan.featured ? 'text-white/85' : 'text-slate-400']}>
                  {feature}
                </span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href="#contact"
            class:list={[
              'block w-full text-center font-semibold text-sm py-3.5 rounded-xl transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]',
              plan.featured
                ? 'bg-white text-brand hover:bg-white/95'
                : 'bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-white'
            ]}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Note -->
    {pricing.note && (
      <p class="mt-10 text-center text-slate-600 text-sm max-w-lg mx-auto">
        {pricing.note}
      </p>
    )}

  </div>
</section>
