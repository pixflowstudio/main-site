---
interface ContactForm {
  namePlaceholder: string;
  emailPlaceholder: string;
  businessPlaceholder: string;
  messagePlaceholder: string;
  submit: string;
  sending: string;
  successTitle: string;
  successMessage: string;
  errorMessage: string;
}

interface ContactContent {
  badge: string;
  headline: string;
  subheadline: string;
  form: ContactForm;
  directContact: string;
  email: string;
  phone: string;
  responseTime: string;
}

export interface Props {
  contact: ContactContent;
  lang: 'en' | 'bg';
}

const { contact, lang } = Astro.props;
---

<section id="contact" class="relative py-24 sm:py-32" aria-labelledby="contact-headline">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-brand/[0.04] to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

      <!-- Left: Text content -->
      <div>
        <p class="section-badge mb-4">{contact.badge}</p>
        <h2 id="contact-headline" class="section-headline mb-5">{contact.headline}</h2>
        <p class="text-slate-400 text-lg leading-relaxed mb-10">
          {contact.subheadline}
        </p>

        <!-- Direct contact -->
        <div class="space-y-4 mb-8">
          <p class="text-slate-500 text-sm">{contact.directContact}</p>

          <a
            href={`mailto:${contact.email}`}
            class="flex items-center gap-3 text-slate-300 hover:text-white transition-colors duration-150 group"
          >
            <div class="w-10 h-10 rounded-xl bg-brand/10 border border-brand/20 flex items-center justify-center text-brand-light flex-shrink-0 group-hover:bg-brand/15 transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <span class="text-sm font-medium">{contact.email}</span>
          </a>

          <a
            href={`tel:${contact.phone.replace(/\s/g, '')}`}
            class="flex items-center gap-3 text-slate-300 hover:text-white transition-colors duration-150 group"
          >
            <div class="w-10 h-10 rounded-xl bg-brand/10 border border-brand/20 flex items-center justify-center text-brand-light flex-shrink-0 group-hover:bg-brand/15 transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 10.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17.92z"/>
              </svg>
            </div>
            <span class="text-sm font-medium">{contact.phone}</span>
          </a>
        </div>

        <!-- Response time note -->
        <p class="text-slate-600 text-sm flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          {contact.responseTime}
        </p>
      </div>

      <!-- Right: Contact form -->
      <div class="card">
        <!-- Success state (hidden by default) -->
        <div id="form-success" class="hidden text-center py-8" aria-live="polite">
          <div class="w-14 h-14 rounded-full bg-green-500/10 border border-green-500/20 flex items-center justify-center mx-auto mb-5">
            <svg class="text-green-400" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">{contact.form.successTitle}</h3>
          <p class="text-slate-400 text-sm">{contact.form.successMessage}</p>
        </div>

        <!-- Form -->
        <form id="contact-form" class="space-y-4" novalidate aria-label="Contact form">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="contact-name" class="sr-only">{contact.form.namePlaceholder}</label>
              <input
                id="contact-name"
                type="text"
                name="name"
                placeholder={contact.form.namePlaceholder}
                required
                autocomplete="name"
                class="w-full bg-white/[0.04] border border-white/[0.08] hover:border-white/[0.12] focus:border-brand/50 focus:bg-white/[0.06] text-white placeholder-slate-600 text-sm px-4 py-3 rounded-xl outline-none transition-all duration-150"
              />
            </div>
            <div>
              <label for="contact-email" class="sr-only">{contact.form.emailPlaceholder}</label>
              <input
                id="contact-email"
                type="email"
                name="email"
                placeholder={contact.form.emailPlaceholder}
                required
                autocomplete="email"
                class="w-full bg-white/[0.04] border border-white/[0.08] hover:border-white/[0.12] focus:border-brand/50 focus:bg-white/[0.06] text-white placeholder-slate-600 text-sm px-4 py-3 rounded-xl outline-none transition-all duration-150"
              />
            </div>
          </div>

          <div>
            <label for="contact-business" class="sr-only">{contact.form.businessPlaceholder}</label>
            <input
              id="contact-business"
              type="text"
              name="business"
              placeholder={contact.form.businessPlaceholder}
              autocomplete="organization"
              class="w-full bg-white/[0.04] border border-white/[0.08] hover:border-white/[0.12] focus:border-brand/50 focus:bg-white/[0.06] text-white placeholder-slate-600 text-sm px-4 py-3 rounded-xl outline-none transition-all duration-150"
            />
          </div>

          <div>
            <label for="contact-message" class="sr-only">{contact.form.messagePlaceholder}</label>
            <textarea
              id="contact-message"
              name="message"
              placeholder={contact.form.messagePlaceholder}
              rows="5"
              required
              class="w-full bg-white/[0.04] border border-white/[0.08] hover:border-white/[0.12] focus:border-brand/50 focus:bg-white/[0.06] text-white placeholder-slate-600 text-sm px-4 py-3 rounded-xl outline-none transition-all duration-150 resize-none"
            ></textarea>
          </div>

          <!-- Error message -->
          <p id="form-error" class="hidden text-red-400 text-sm" role="alert">
            {contact.form.errorMessage}
          </p>

          <button
            type="submit"
            id="form-submit"
            class="btn-primary w-full text-sm py-3.5"
          >
            <span id="submit-text">{contact.form.submit}</span>
            <svg id="submit-spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
            </svg>
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successDiv = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');
  const submitBtn = document.getElementById('form-submit') as HTMLButtonElement | null;
  const submitText = document.getElementById('submit-text');
  const submitSpinner = document.getElementById('submit-spinner');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    // Reset state
    errorMsg?.classList.add('hidden');

    // Show loading state
    if (submitBtn) submitBtn.disabled = true;
    submitText?.classList.add('hidden');
    submitSpinner?.classList.remove('hidden');

    try {
      const response = await fetch('https://formspree.io/f/meepobzo', {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (!response.ok) throw new Error('Failed');

      form.classList.add('hidden');
      successDiv?.classList.remove('hidden');
    } catch {
      errorMsg?.classList.remove('hidden');
      if (submitBtn) submitBtn.disabled = false;
      submitText?.classList.remove('hidden');
      submitSpinner?.classList.add('hidden');
    }
  });
</script>
