---
interface FaqItem {
  question: string;
  answer: string;
}

interface FaqContent {
  badge: string;
  headline: string;
  subheadline: string;
  items: FaqItem[];
}

export interface Props {
  faq: FaqContent;
}

const { faq } = Astro.props;
---

<section id="faq" class="relative py-24 sm:py-32" aria-labelledby="faq-headline">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 sm:mb-20">
      <p class="section-badge justify-center mb-4">{faq.badge}</p>
      <h2 id="faq-headline" class="section-headline mb-5">{faq.headline}</h2>
      <p class="section-subheadline mx-auto">{faq.subheadline}</p>
    </div>

    <div class="space-y-4">
      {faq.items.map((item) => (
        <details class="card group">
          <summary class="list-none cursor-pointer flex items-start justify-between gap-4">
            <h3 class="text-left text-white font-semibold text-base leading-snug">
              {item.question}
            </h3>
            <span class="text-brand-light text-xl leading-none transition-transform duration-200 group-open:rotate-45" aria-hidden="true">+</span>
          </summary>
          <p class="mt-4 text-slate-400 text-sm leading-relaxed">
            {item.answer}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>
