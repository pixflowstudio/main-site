---
import '../styles/global.css';
import CookieBanner from '../components/common/CookieBanner.astro';

export interface Props {
  title: string;
  description: string;
  lang: 'en' | 'bg';
  ogImage?: string;
}

const {
  title,
  description,
  lang,
  ogImage = '/logo.png',
} = Astro.props;

const siteUrl = 'https://pixflowstudio.com';
const pathname = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonicalUrl = `${siteUrl}${pathname}`;
const alternateUrl = lang === 'en'
  ? `${siteUrl}/bg${pathname}`
  : `${siteUrl}${pathname.replace(/^\/bg/, '') || '/'}`;
const alternateLang = lang === 'en' ? 'bg' : 'en';
const xDefaultUrl = lang === 'en' ? canonicalUrl : alternateUrl;

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Pixflow Studio",
    "url": siteUrl,
    "logo": `${siteUrl}/logo.png`,
    "email": "contact@pixflowstudio.com",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "email": "contact@pixflowstudio.com",
      "availableLanguage": ["English", "Bulgarian"]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "ProfessionalService"],
    "name": "Pixflow Studio",
    "url": siteUrl,
    "logo": `${siteUrl}/logo.png`,
    "email": "contact@pixflowstudio.com",
    "description": "We design, build, and host modern websites for small local businesses. Starting at €25/month. No contracts, no upfront cost.",
    "areaServed": {
      "@type": "Country",
      "name": "Bulgaria"
    },
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "BG"
    },
    "priceRange": "€25–€39/month",
    "serviceType": "Web Design & Development",
    "currenciesAccepted": "EUR",
    "paymentAccepted": "Bank Transfer, Card"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Pixflow Studio",
    "url": siteUrl,
    "inLanguage": ["en", "bg"],
    "description": description
  }
];
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary Meta -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Hreflang -->
  <link rel="alternate" hreflang={lang} href={canonicalUrl} />
  <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
  <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Pixflow Studio" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:image:alt" content="Pixflow Studio" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(schemas)} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#0A0B14" />

  <slot name="head" />
</head>
<body class="bg-[#0A0B14] text-slate-100 antialiased font-sans">
  <slot />
  <CookieBanner lang={lang} />
</body>
</html>
