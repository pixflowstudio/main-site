---
import InnerLayout from '../layouts/InnerLayout.astro';
import content from '../content/en/privacy.json';
---

<InnerLayout
  title="Privacy Policy — Pixflow Studio"
  description="How Pixflow Studio collects, uses, and protects your personal data. GDPR compliant."
  lang="en"
>
  <!-- Page header -->
  <div class="mb-12 pb-10 border-b border-white/[0.06]">
    <a href="/" class="inline-flex items-center gap-2 text-slate-500 hover:text-white text-sm mb-8 transition-colors">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Back to home
    </a>
    <h1 class="text-3xl sm:text-4xl font-black text-white mb-4 tracking-tight">{content.title}</h1>
    <p class="text-slate-400 text-lg leading-relaxed mb-3">{content.subtitle}</p>
    <p class="text-slate-600 text-sm">Last updated: {content.lastUpdated}</p>
  </div>

  <!-- Controller -->
  <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-6 mb-10">
    <h2 class="text-white font-bold mb-2">{content.controller.title}</h2>
    <p class="text-slate-400 text-sm leading-relaxed mb-3">{content.controller.body}</p>
    <a href={`mailto:${content.controller.contact}`} class="text-brand-light text-sm hover:text-white transition-colors">{content.controller.contact}</a>
  </div>

  <!-- Sections -->
  <div class="space-y-10">
    {content.sections.map((section) => (
      <div>
        <h2 class="text-xl font-bold text-white mb-4">{section.title}</h2>

        {'items' in section && section.items ? (
          <div class="space-y-4">
            {section.items.map((item) => (
              <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-5">
                <h3 class="text-white font-semibold text-sm mb-2">{item.heading}</h3>
                <p class="text-slate-400 text-sm leading-relaxed">{item.body}</p>
              </div>
            ))}
          </div>
        ) : 'rights' in section && section.rights ? (
          <div>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">{section.body}</p>
            <ul class="space-y-2 mb-4">
              {section.rights.map((right) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-300">
                  <svg class="text-brand-light flex-shrink-0 mt-0.5" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                  {right}
                </li>
              ))}
            </ul>
            <p class="text-slate-500 text-sm leading-relaxed">{section.footer}</p>
          </div>
        ) : (
          <p class="text-slate-400 text-sm leading-relaxed">{section.body}</p>
        )}
      </div>
    ))}
  </div>
</InnerLayout>
