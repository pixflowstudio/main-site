---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/layout/Nav.astro';
import Footer from '../../components/layout/Footer.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import Pricing from '../../components/sections/Pricing.astro';
import Process from '../../components/sections/Process.astro';
import Trust from '../../components/sections/Trust.astro';
import Contact from '../../components/sections/Contact.astro';
import FAQ from '../../components/sections/FAQ.astro';

// Content imports
import company from '../../content/bg/company.json';
import services from '../../content/bg/services.json';
import pricing from '../../content/bg/pricing.json';
import process from '../../content/bg/process.json';
import trust from '../../content/bg/trust.json';
import contact from '../../content/bg/contact.json';
import faq from '../../content/bg/faq.json';

const lang = 'bg' as const;
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.items.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<BaseLayout
  title="Достъпна Изработка на Сайт за Бизнес | Pixflow Studio"
  description="Достъпна изработка на сайт за малък бизнес, стартъпи и местни услуги. Бърз старт, включен хостинг и пускане до 48-72 часа от €25/месец."
  lang={lang}
  schemaOverrides={[faqSchema]}
>
  <Nav lang={lang} nav={company.nav} />

  <main>
    <Hero hero={company.hero} lang={lang} />
    <Services services={services} />
    <Pricing pricing={pricing} />
    <Process process={process} />
    <Trust trust={trust} />
    <FAQ faq={faq} />
    <Contact contact={contact} lang={lang} />
  </main>

  <Footer
    lang={lang}
    footer={company.footer}
    email={company.email}
    whatsapp={company.whatsapp}
  />
</BaseLayout>
